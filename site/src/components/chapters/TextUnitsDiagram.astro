---
import {
  assertTextUnitsDiagramLabels,
  formatByteCount,
  textUnitsDiagramId,
  textUnitsExamples,
  type TextUnitsDiagramLabels,
} from '../../lib/text-units-diagram';

interface Props {
  labels: TextUnitsDiagramLabels;
  id?: string;
}

const { labels, id = textUnitsDiagramId } = Astro.props;
assertTextUnitsDiagramLabels(labels);

const titleId = `${id}-title`;
const descriptionId = `${id}-description`;
const stageLabels = [
  labels.stages.input,
  labels.stages.bytes,
  labels.stages.scalars,
  labels.stages.tokenIds,
];
---

<figure
  class="text-units-diagram"
  data-visualization-id={textUnitsDiagramId}
  id={id}
  tabindex="0"
  aria-labelledby={titleId}
  aria-describedby={descriptionId}
>
  <figcaption id={titleId}>{labels.title}</figcaption>
  <p class="diagram-description" id={descriptionId}>{labels.description}</p>

  <div class="diagram-examples">
    {
      textUnitsExamples.map((example) => {
        const exampleTitleId = `${id}-${example.id}-title`;
        return (
          <section class="diagram-example" aria-labelledby={exampleTitleId}>
            <h3 id={exampleTitleId}>{labels.examples[example.id]}</h3>
            <ol
              class="text-units-pipeline"
              aria-label={labels.pipelineLabel}
              dir="ltr"
            >
              <li class="pipeline-stage" data-stage="input">
                <span class="stage-number" aria-hidden="true">01</span>
                <h4 dir="auto">{stageLabels[0]}</h4>
                <ol class="unit-list" aria-label={stageLabels[0]}>
                  {
                    example.units.map((unit) => (
                      <li><code dir="ltr">{unit.value}</code></li>
                    ))
                  }
                </ol>
              </li>

              <li class="pipeline-stage" data-stage="bytes">
                <span class="stage-number" aria-hidden="true">02</span>
                <h4 dir="auto">{stageLabels[1]}</h4>
                <ol class="unit-list" aria-label={stageLabels[1]}>
                  {
                    example.units.map((unit) => (
                      <li>
                        <code class="byte-group" dir="ltr">
                          <span aria-hidden="true">[</span>
                          {unit.bytes.join(' ')}
                          <span aria-hidden="true">]</span>
                        </code>
                        <small dir="auto">
                          {formatByteCount(labels.byteCount, unit.bytes.length)}
                        </small>
                      </li>
                    ))
                  }
                </ol>
              </li>

              <li class="pipeline-stage" data-stage="scalars">
                <span class="stage-number" aria-hidden="true">03</span>
                <h4 dir="auto">{stageLabels[2]}</h4>
                <ol class="unit-list" aria-label={stageLabels[2]}>
                  {
                    example.units.map((unit) => (
                      <li>
                        <code dir="ltr">{unit.scalar}</code>
                        <small dir="ltr">{unit.value}</small>
                      </li>
                    ))
                  }
                </ol>
              </li>

              <li class="pipeline-stage" data-stage="token-ids">
                <span class="stage-number" aria-hidden="true">04</span>
                <h4 dir="auto">{stageLabels[3]}</h4>
                <ol class="unit-list" aria-label={stageLabels[3]}>
                  {
                    example.units.map((unit) => (
                      <li><code dir="ltr">{unit.tokenId}</code></li>
                    ))
                  }
                </ol>
              </li>
            </ol>
          </section>
        );
      })
    }
  </div>
</figure>

<style>
  .text-units-diagram {
    margin-block: 2rem;
    padding: clamp(1rem, 3vw, 1.6rem);
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .text-units-diagram:focus-visible {
    outline: 0.2rem solid var(--focus);
    outline-offset: 0.25rem;
  }

  figcaption {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.15;
  }

  .diagram-description {
    max-width: 68ch;
    margin: 0.65rem 0 0;
    color: var(--muted);
  }

  .diagram-examples {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .diagram-example {
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  h3,
  h4 {
    margin: 0;
  }

  h3 {
    font-size: 1rem;
  }

  .text-units-pipeline,
  .unit-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .text-units-pipeline {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.35rem;
    margin-top: 0.75rem;
  }

  .pipeline-stage {
    position: relative;
    min-width: 0;
    padding: 0.85rem;
    border: 1px solid var(--line);
    border-top: 0.3rem solid var(--accent);
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .pipeline-stage:not(:last-child)::after {
    position: absolute;
    z-index: 1;
    top: 50%;
    inset-inline-start: calc(100% + 0.25rem);
    width: 0.85rem;
    color: var(--accent-dark);
    content: "→";
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    transform: translateY(-50%);
  }

  .stage-number {
    display: block;
    color: var(--warm);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  h4 {
    margin-top: 0.2rem;
    font-size: 0.85rem;
    line-height: 1.25;
  }

  .unit-list {
    display: grid;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }

  .unit-list > li {
    display: flex;
    min-width: 0;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem;
    padding: 0.45rem 0.5rem;
    border: 1px dashed var(--line);
    border-radius: 0.45rem;
    background: rgba(247, 244, 236, 0.8);
  }

  code {
    direction: ltr;
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    unicode-bidi: isolate;
  }

  small {
    color: var(--muted);
    font-size: 0.67rem;
    line-height: 1.2;
    text-align: end;
  }

  @media (max-width: 44rem) {
    .text-units-pipeline {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .pipeline-stage:not(:last-child)::after {
      top: calc(100% + 0.2rem);
      inset-inline-start: 50%;
      content: "↓";
      transform: translateX(-50%);
    }

    .unit-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .unit-list > li {
      align-items: flex-start;
      flex-direction: column;
    }

    small {
      text-align: start;
    }
  }

  @media (max-width: 28rem) {
    .unit-list {
      grid-template-columns: 1fr;
    }
  }

  @media (forced-colors: active) {
    .pipeline-stage,
    .unit-list > li {
      border-color: CanvasText;
    }
  }
</style>
