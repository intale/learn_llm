---
import 'katex/dist/katex.min.css';
import '../styles/global.css';

import {
  getLocaleDefinition,
  getMessages,
  localeDefinitions,
  localePath,
  locales,
  type Locale,
} from '../i18n';
import { sitePath } from '../lib/site-path';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  routeSuffix?: string;
  equivalentLocales?: readonly Locale[];
  fallbackRouteSuffix?: string;
}

const {
  locale,
  routeSuffix = '/',
  equivalentLocales = locales,
  fallbackRouteSuffix,
} = Astro.props;
const copy = getMessages(locale);
const title = Astro.props.title ?? copy.siteTitle;
const description = Astro.props.description ?? copy.siteDescription;
const fullTitle = title === copy.siteTitle ? title : `${title} · ${copy.siteTitle}`;
const localeDefinition = getLocaleDefinition(locale);
if (
  equivalentLocales.length === 0 ||
  new Set(equivalentLocales).size !== equivalentLocales.length ||
  equivalentLocales.some((candidate) => !locales.includes(candidate)) ||
  !equivalentLocales.includes(locale)
) {
  throw new Error('Equivalent route locales must be registered, unique, and include the current locale.');
}
const equivalentLocaleSet = new Set<Locale>(equivalentLocales);
const equivalentDefinitions = localeDefinitions.filter((candidate) =>
  equivalentLocaleSet.has(candidate.code),
);
const switchTargets = localeDefinitions
  .filter((candidate) => candidate.code !== locale)
  .flatMap((candidate) => {
    const equivalent = equivalentLocaleSet.has(candidate.code);
    const suffix = equivalent ? routeSuffix : fallbackRouteSuffix;
    if (!suffix) return [];
    return [{
      definition: candidate,
      equivalent,
      href: localePath(candidate.code, suffix),
      fallbackLabel: equivalent ? null : getMessages(candidate.code).allChaptersLabel,
    }];
  });
---

<!doctype html>
<html lang={localeDefinition.languageTag} dir={localeDefinition.direction}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <title>{fullTitle}</title>
    {
      equivalentDefinitions.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.languageTag}
          href={localePath(alternate.code, routeSuffix)}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={sitePath('/')} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{copy.skipToContent}</a>
    <header class="site-header">
      <a class="wordmark" href={localePath(locale)} aria-label={copy.homeLabel}>
        <span aria-hidden="true" class="wordmark-mark">λ</span>
        <span>{copy.siteTitle}</span>
      </a>
      <nav class="locale-switch" aria-label={copy.languageSwitchLabel}>
        <span>{copy.languageSwitchLabel}</span>
        {
          switchTargets.map(({ definition: alternate, equivalent, href, fallbackLabel }) => (
            <a
              href={href}
              lang={alternate.languageTag}
              dir={alternate.direction}
              hreflang={alternate.languageTag}
              data-locale={alternate.code}
              data-locale-fallback={equivalent ? undefined : 'course-index'}
              aria-label={fallbackLabel ? `${alternate.nativeName}: ${fallbackLabel}` : undefined}
            >
              <span>{alternate.nativeName}</span>
              {fallbackLabel && <small>{fallbackLabel}</small>}
            </a>
          ))
        }
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>{copy.footerNote}</p>
    </footer>
  </body>
</html>

<style>
  .locale-switch a span,
  .locale-switch a small {
    display: block;
  }

  .locale-switch a small {
    font-size: 0.7em;
    font-weight: 500;
  }
</style>
