---
import '../styles/global.css';

import {
  defaultLocale,
  getMessages,
  localeDefinitions,
  localePath,
} from '../i18n';
import { sitePath } from '../lib/site-path';

const pickerCopy = localeDefinitions.map((locale) => ({
  ...locale,
  messages: getMessages(locale.code),
}));
const defaultCopy = getMessages(defaultLocale);
---

<!doctype html>
<html lang="mul" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content={defaultCopy.siteDescription}
    />
    <meta name="color-scheme" content="light" />
    <title>{defaultCopy.languagePickerTitle}</title>
    {
      pickerCopy.map((entry) => (
        <link
          rel="alternate"
          hreflang={entry.languageTag}
          href={localePath(entry.code)}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={sitePath('/')} />
  </head>
  <body class="language-page">
    <main class="language-picker" aria-labelledby="language-title">
      <span class="language-picker-mark" aria-hidden="true">λ</span>
      <p class="eyebrow">
        {
          pickerCopy.map((entry, index) => (
            <>
              <span lang={entry.languageTag} dir={entry.direction}>
                {entry.messages.siteTitle}
              </span>
              {index < pickerCopy.length - 1 && <span aria-hidden="true"> · </span>}
            </>
          ))
        }
      </p>
      <h1 id="language-title">
        {
          pickerCopy.map((entry) => (
            <span lang={entry.languageTag} dir={entry.direction}>
              {entry.messages.languagePickerTitle}
            </span>
          ))
        }
      </h1>
      <p class="language-intro">
        {
          pickerCopy.map((entry) => (
            <span lang={entry.languageTag} dir={entry.direction}>
              {entry.messages.languagePickerIntro}
            </span>
          ))
        }
      </p>
      <nav
        class="language-options"
        aria-label={defaultCopy.languageSwitchLabel}
      >
        {
          pickerCopy.map((entry) => (
            <a
              href={localePath(entry.code)}
              lang={entry.languageTag}
              dir={entry.direction}
              hreflang={entry.languageTag}
              data-locale={entry.code}
            >
              <span>{entry.nativeName}</span>
              <span aria-hidden="true" dir="ltr">
                {
                  entry.direction === 'rtl'
                    ? `← ${entry.code.toLocaleUpperCase()}`
                    : `${entry.code.toLocaleUpperCase()} →`
                }
              </span>
            </a>
          ))
        }
      </nav>
    </main>
  </body>
</html>
