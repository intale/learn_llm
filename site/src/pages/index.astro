---
import '../styles/global.css';
---

<!doctype html>
<html lang="mul">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Choose English or Russian for a course about building a language model in Rust."
    />
    <meta name="color-scheme" content="light" />
    <title>Choose a language · Выберите язык</title>
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="ru" href="/ru/" />
    <link rel="alternate" hreflang="x-default" href="/" />
  </head>
  <body class="language-page">
    <main class="language-picker" aria-labelledby="language-title">
      <span class="language-picker-mark" aria-hidden="true">λ</span>
      <p class="eyebrow">LLM, piece by piece · LLM по частям</p>
      <h1 id="language-title">Choose a language<br /><span lang="ru">Выберите язык</span></h1>
      <p class="language-intro">
        Build a language model from first principles in Rust.<br />
        <span lang="ru">Соберите языковую модель с нуля на Rust.</span>
      </p>
      <nav class="language-options" aria-label="Language · Язык">
        <a href="/en/" lang="en" hreflang="en">
          <span>English</span>
          <span aria-hidden="true">EN →</span>
        </a>
        <a href="/ru/" lang="ru" hreflang="ru">
          <span>Русский</span>
          <span aria-hidden="true">RU →</span>
        </a>
      </nav>
    </main>
  </body>
</html>
