---
import { getCollection } from 'astro:content';

import {
  getMessages,
  localePath,
  locales,
  type Locale,
} from '../../../i18n';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { findPublishableChapterSets } from '../../../lib/chapter-publication';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const chapterModules = import.meta.glob(
  '../../../content/chapters/**/*.{md,mdx}',
);
const allChapters =
  Object.keys(chapterModules).length === 0 ? [] : await getCollection('chapters');
const chapters = findPublishableChapterSets(allChapters)
  .flatMap((set) => {
    const localized = set.byLocale[locale];
    return localized ? [localized] : [];
  })
  .sort((left, right) => left.data.order - right.data.order);

const copy = getMessages(locale);
---

<BaseLayout
  locale={locale}
  routeSuffix="/course/"
  title={copy.courseTitle}
  description={copy.courseDescription}
>
  <section class="hero shell-container course-hero">
    <p class="eyebrow">{copy.courseEyebrow}</p>
    <h1>{copy.courseTitle}</h1>
    <p class="hero-intro">{copy.courseDescription}</p>
  </section>

  {
    chapters.length > 0 ? (
      <ol class="feature-grid shell-container course-list">
        {chapters.map((chapter) => (
          <li>
            <article class="feature-card">
              <span class="feature-number" aria-hidden="true">
                {String(chapter.data.order).padStart(2, '0')}
              </span>
              <h2>
                <a href={localePath(locale, `/course/${chapter.data.chapter_id}/`)}>
                  {chapter.data.title}
                </a>
              </h2>
              <p>{chapter.data.description}</p>
              <small>{copy.contentRevisionLabel}: {chapter.data.content_revision}</small>
            </article>
          </li>
        ))}
      </ol>
    ) : (
      <aside class="course-note shell-container">
        <span aria-hidden="true">⌁</span>
        <p>{copy.courseEmpty}</p>
      </aside>
    )
  }
</BaseLayout>

<style>
  .course-hero {
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .course-list {
    margin-top: 0;
    margin-bottom: 6rem;
    padding: 0;
    list-style: none;
  }

  .course-list li {
    min-width: 0;
  }

  .course-list h2 a {
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .course-list small {
    display: block;
    margin-top: 1.25rem;
    color: var(--accent-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
</style>
