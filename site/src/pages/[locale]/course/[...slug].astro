---
import {
  getCollection,
  render,
  type CollectionEntry,
} from 'astro:content';

import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import RustSource from '../../../components/RustSource.astro';
import {
  getLocaleDefinition,
  getMessages,
  localePath,
  type Locale,
} from '../../../i18n';
import {
  findChapterNeighbors,
  type ChapterNavigationTarget,
} from '../../../lib/chapter-navigation';
import { findPublishableChapterSets } from '../../../lib/chapter-publication';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const chapterModules = import.meta.glob(
    '../../../content/chapters/**/*.{md,mdx}',
  );
  const chapters =
    Object.keys(chapterModules).length === 0 ? [] : await getCollection('chapters');
  const publishable = findPublishableChapterSets(chapters).flatMap((set) =>
    set.activeLocales.flatMap((locale) => {
      const entry = set.byLocale[locale];
      if (!entry) {
        throw new Error(
          `Publishable chapter ${set.chapterId} is missing active locale ${locale}.`,
        );
      }
      return [{
        entry,
        equivalentLocales: set.activeLocales as readonly Locale[],
      }];
    }),
  );

  return publishable.map(({ entry, equivalentLocales }) => {
    const localizedTargets = publishable
      .filter((candidate) => candidate.entry.data.locale === entry.data.locale)
      .map((candidate) => ({
        chapterId: candidate.entry.data.chapter_id,
        order: candidate.entry.data.order,
        title: candidate.entry.data.title,
      }));
    const { previous, next } = findChapterNeighbors(
      localizedTargets,
      entry.data.chapter_id,
    );

    return {
      params: {
        locale: entry.data.locale,
        slug: entry.data.chapter_id,
      },
      props: { entry, previous, next, equivalentLocales },
    };
  });
}

const { entry, previous, next, equivalentLocales } = Astro.props as {
  entry: CollectionEntry<'chapters'>;
  previous: ChapterNavigationTarget | null;
  next: ChapterNavigationTarget | null;
  equivalentLocales: readonly Locale[];
};
const { Content } = await render(entry);
const locale = entry.data.locale;
const copy = getMessages(locale);
const backArrow = getLocaleDefinition(locale).direction === 'rtl' ? '→' : '←';
const routeSuffix = '/course/' + entry.data.chapter_id + '/';
---

<BaseLayout
  locale={locale}
  routeSuffix={routeSuffix}
  equivalentLocales={equivalentLocales}
  fallbackRouteSuffix="/course/"
  title={entry.data.title}
  description={entry.data.description}
>
  <article class="lesson shell-container">
    <header class="lesson-header">
      <a class="lesson-back" href={localePath(locale, '/course/')}>
        {backArrow} {copy.allChaptersLabel}
      </a>
      <p class="eyebrow">
        {String(entry.data.order).padStart(2, '0')} · {copy.contentRevisionLabel} {entry.data.content_revision}
      </p>
      <h1>{entry.data.title}</h1>
      <p class="lesson-description">{entry.data.description}</p>
      <aside class="lesson-objective">
        <strong>{copy.chapterObjectiveLabel}</strong>
        <p>{entry.data.objective}</p>
      </aside>
    </header>

    <div class="lesson-body">
      <Content components={{ RustSource }} />
    </div>

    <ChapterNavigation locale={locale} previous={previous} next={next} />
  </article>
</BaseLayout>

<style is:global>
  .lesson {
    max-width: 52rem;
    padding-block: clamp(3rem, 8vw, 6rem);
  }

  .lesson-header {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--line);
  }

  .lesson-back {
    display: inline-block;
    margin-bottom: 2.5rem;
    color: var(--accent-dark);
    font-weight: 750;
    text-underline-offset: 0.2rem;
  }

  .lesson h1 {
    max-width: 15ch;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    font-weight: 500;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .lesson-description {
    margin: 1.5rem 0 0;
    color: var(--muted);
    font-size: 1.2rem;
  }

  .lesson-objective {
    margin-top: 2rem;
    padding: 1.1rem 1.25rem;
    border-inline-start: 0.25rem solid var(--accent);
    background: rgba(15, 118, 110, 0.08);
  }

  .lesson-objective p {
    margin: 0.35rem 0 0;
  }

  .lesson-body {
    padding-top: 2rem;
  }

  .lesson-body h2 {
    margin: 3.5rem 0 1rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 500;
    line-height: 1.12;
  }

  .lesson-body h3 {
    margin-top: 2rem;
    font-size: 1.25rem;
  }

  .lesson-body p,
  .lesson-body li {
    max-width: 70ch;
  }

  .lesson-body blockquote {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-inline-start: 0.2rem solid var(--warm);
    color: var(--muted);
  }

  .lesson-body :not(pre) > code {
    direction: ltr;
    padding: 0.12rem 0.3rem;
    border-radius: 0.3rem;
    background: rgba(22, 33, 29, 0.08);
    font-size: 0.9em;
    unicode-bidi: isolate;
  }

  .lesson-body .katex,
  .lesson-body .katex-display {
    direction: ltr;
    unicode-bidi: isolate;
  }

  .lesson-body .katex-display {
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .lesson-body table {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .lesson-body th,
  .lesson-body td {
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--line);
    text-align: start;
  }

  html[dir="rtl"] .lesson h1 {
    letter-spacing: normal;
  }
</style>
